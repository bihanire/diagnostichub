# Next.js runtime environment
# File target: /etc/diaghub/frontend.env

NEXT_PUBLIC_API_BASE_URL=/api
BACKEND_INTERNAL_URL=http://127.0.0.1:8000
NEXT_PUBLIC_ENABLE_SERVICE_WORKER=false
NEXT_PUBLIC_BOOT_HANDSHAKE_ENABLED=true
NEXT_PUBLIC_BOOT_HANDSHAKE_TIMEOUT_MS=5000
NEXT_PUBLIC_ENFORCE_API_GATEWAY=true
NEXT_PUBLIC_API_VERSION_CHECK_ENABLED=true
NEXT_PUBLIC_EXPECTED_API_VERSION=1.0.0
NEXT_PUBLIC_CLIENT_REQUEST_ID_ENABLED=true
