# FastAPI runtime environment
# File target: /etc/diaghub/backend.env

DATABASE_URL=postgresql+psycopg://postgres:change-me@127.0.0.1:5432/diaghub
CORS_ORIGINS=https://diaghub.watuafrica.co.ug
CORS_ALLOW_LOCAL_NETWORK=false
SEED_ON_STARTUP=false
STRICT_WORKFLOW_VALIDATION=true
LOG_LEVEL=INFO

OPS_AUTH_ENABLED=true
OPS_SHARED_PASSWORD=change-me
OPS_SESSION_SECRET=change-me-with-a-long-random-secret
OPS_SESSION_TTL_HOURS=8
OPS_COOKIE_NAME=rel_ops_session
OPS_COOKIE_SECURE=true
