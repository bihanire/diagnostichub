# Deploy worker environment
# File target: /etc/diaghub/deploy.env

APP_ROOT=/opt/diaghub
REPO_DIR=/opt/diaghub/repo
DEPLOY_BRANCH=main
GIT_REMOTE=origin
VENV_DIR=/opt/diaghub/venv

BACKEND_SERVICE=diaghub-backend.service
FRONTEND_SERVICE=diaghub-frontend.service

BACKEND_HEALTH_URL=http://127.0.0.1:8000/health
BACKEND_READY_URL=http://127.0.0.1:8000/ready
FRONTEND_HEALTH_URL=http://127.0.0.1:3000

DEPLOY_LOG=/var/log/diaghub-deploy.log
LOCK_FILE=/var/lock/diaghub-deploy.lock
STATE_DIR=/var/lib/diaghub
