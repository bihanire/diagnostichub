FROM node:20-alpine AS deps

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

FROM node:20-alpine AS builder

WORKDIR /app

ARG NEXT_PUBLIC_API_BASE_URL=/api
ARG NEXT_PUBLIC_ENABLE_SERVICE_WORKER=false
ARG NEXT_PUBLIC_BOOT_HANDSHAKE_ENABLED=true
ARG NEXT_PUBLIC_BOOT_HANDSHAKE_TIMEOUT_MS=5000
ARG NEXT_PUBLIC_ENFORCE_API_GATEWAY=true
ARG NEXT_PUBLIC_API_VERSION_CHECK_ENABLED=true
ARG NEXT_PUBLIC_EXPECTED_API_VERSION=1.0.0
ARG NEXT_PUBLIC_CLIENT_REQUEST_ID_ENABLED=true
ARG BACKEND_INTERNAL_URL=http://127.0.0.1:8000
ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_ENABLE_SERVICE_WORKER=$NEXT_PUBLIC_ENABLE_SERVICE_WORKER
ENV NEXT_PUBLIC_BOOT_HANDSHAKE_ENABLED=$NEXT_PUBLIC_BOOT_HANDSHAKE_ENABLED
ENV NEXT_PUBLIC_BOOT_HANDSHAKE_TIMEOUT_MS=$NEXT_PUBLIC_BOOT_HANDSHAKE_TIMEOUT_MS
ENV NEXT_PUBLIC_ENFORCE_API_GATEWAY=$NEXT_PUBLIC_ENFORCE_API_GATEWAY
ENV NEXT_PUBLIC_API_VERSION_CHECK_ENABLED=$NEXT_PUBLIC_API_VERSION_CHECK_ENABLED
ENV NEXT_PUBLIC_EXPECTED_API_VERSION=$NEXT_PUBLIC_EXPECTED_API_VERSION
ENV NEXT_PUBLIC_CLIENT_REQUEST_ID_ENABLED=$NEXT_PUBLIC_CLIENT_REQUEST_ID_ENABLED
ENV BACKEND_INTERNAL_URL=$BACKEND_INTERNAL_URL

COPY --from=deps /app/node_modules ./node_modules
COPY . .

RUN npm run build

FROM node:20-alpine AS runner

WORKDIR /app

ARG NEXT_PUBLIC_API_BASE_URL=/api
ARG NEXT_PUBLIC_ENABLE_SERVICE_WORKER=false
ARG NEXT_PUBLIC_BOOT_HANDSHAKE_ENABLED=true
ARG NEXT_PUBLIC_BOOT_HANDSHAKE_TIMEOUT_MS=5000
ARG NEXT_PUBLIC_ENFORCE_API_GATEWAY=true
ARG NEXT_PUBLIC_API_VERSION_CHECK_ENABLED=true
ARG NEXT_PUBLIC_EXPECTED_API_VERSION=1.0.0
ARG NEXT_PUBLIC_CLIENT_REQUEST_ID_ENABLED=true
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_ENABLE_SERVICE_WORKER=$NEXT_PUBLIC_ENABLE_SERVICE_WORKER
ENV NEXT_PUBLIC_BOOT_HANDSHAKE_ENABLED=$NEXT_PUBLIC_BOOT_HANDSHAKE_ENABLED
ENV NEXT_PUBLIC_BOOT_HANDSHAKE_TIMEOUT_MS=$NEXT_PUBLIC_BOOT_HANDSHAKE_TIMEOUT_MS
ENV NEXT_PUBLIC_ENFORCE_API_GATEWAY=$NEXT_PUBLIC_ENFORCE_API_GATEWAY
ENV NEXT_PUBLIC_API_VERSION_CHECK_ENABLED=$NEXT_PUBLIC_API_VERSION_CHECK_ENABLED
ENV NEXT_PUBLIC_EXPECTED_API_VERSION=$NEXT_PUBLIC_EXPECTED_API_VERSION
ENV NEXT_PUBLIC_CLIENT_REQUEST_ID_ENABLED=$NEXT_PUBLIC_CLIENT_REQUEST_ID_ENABLED

RUN addgroup -g 1001 -S nodejs && adduser -S nextjs -u 1001

COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static

USER nextjs

EXPOSE 3000

CMD ["node", "server.js"]
