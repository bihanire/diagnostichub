NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_ENABLE_SERVICE_WORKER=false
NEXT_PUBLIC_BOOT_HANDSHAKE_ENABLED=true
NEXT_PUBLIC_BOOT_HANDSHAKE_TIMEOUT_MS=5000
NEXT_PUBLIC_ENFORCE_API_GATEWAY=true
NEXT_PUBLIC_API_VERSION_CHECK_ENABLED=true
NEXT_PUBLIC_EXPECTED_API_VERSION=1.0.0
NEXT_PUBLIC_CLIENT_REQUEST_ID_ENABLED=true

# ── Google Form pre-fill bridge (Phase 12) ───────────────────────────────────
# Leave blank to hide the "Open Watu form" button entirely.
# NEXT_PUBLIC_GFORM_ID is the form ID from the Google Form edit URL:
#   https://docs.google.com/forms/d/{NEXT_PUBLIC_GFORM_ID}/edit
# Update the entry.XXXXXXXXX IDs in frontend/lib/googleForm.ts after you run
# "Get pre-filled link" from the form's three-dot menu.
NEXT_PUBLIC_GFORM_ID=
