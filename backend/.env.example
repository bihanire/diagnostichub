DATABASE_URL=sqlite:///./relational_encyclopedia.db
CORS_ORIGINS=http://localhost:3000
SEED_ON_STARTUP=true
STRICT_WORKFLOW_VALIDATION=true
STRICT_DATA_INTEGRITY_VALIDATION=true
LOG_LEVEL=INFO
OPS_AUTH_ENABLED=true
OPS_SHARED_PASSWORD=replace-with-unique-shared-passphrase
OPS_SESSION_SECRET=replace-with-64-byte-random-hex
OPS_SESSION_TTL_HOURS=8
OPS_COOKIE_NAME=rel_ops_session
OPS_COOKIE_SECURE=false
READINESS_PROBE_ENABLED=true
READINESS_PROBE_TIMEOUT_MS=450
API_META_ENABLED=true
API_VERSION=1.0.0
SCHEMA_VERSION=1
BUILD_SHA=dev
REQUEST_CORRELATION_ENABLED=true
STANDARDIZE_ERROR_RESPONSES=true

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
# Create credentials at: console.cloud.google.com > APIs & Services > Credentials
# Authorised redirect URI: http://localhost:8000/auth/callback (dev)
#                          https://yourdomain.com/api/auth/callback (prod)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=replace-with-64-byte-random-hex
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── Auth cookies ─────────────────────────────────────────────────────────────
AUTH_COOKIE_NAME=dh_auth
AUTH_COOKIE_SECURE=false
AUTH_REG_COOKIE_NAME=dh_reg
AUTH_REG_COOKIE_EXPIRE_MINUTES=30

# ── Frontend URL (used for OAuth redirects) ───────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Google Sheets sync (Phase 4) ─────────────────────────────────────────────
# Create a service account in Google Cloud Console, share your target sheet with it,
# download the JSON key, then base64-encode it:
#   base64 -i service-account.json | tr -d '\n'
# Leave unset to disable sheet sync silently.
GOOGLE_SHEETS_CREDENTIALS_JSON=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_WORKSHEET_NAME=Cases

# ── Aramex dispatch webhook (Phase 5) ────────────────────────────────────────
# POST is fired when a case status changes to "dispatched".
# Leave unset to disable silently.
ARAMEX_WEBHOOK_URL=
ARAMEX_WEBHOOK_SECRET=
