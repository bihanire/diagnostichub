DATABASE_URL=postgresql+psycopg://<username>:<password>@localhost:5432/relational_encyclopedia
CORS_ORIGINS=http://localhost:3000
SEED_ON_STARTUP=true
STRICT_WORKFLOW_VALIDATION=true
STRICT_DATA_INTEGRITY_VALIDATION=true
LOG_LEVEL=INFO
OPS_AUTH_ENABLED=true
OPS_SHARED_PASSWORD=replace-with-unique-shared-passphrase
OPS_SESSION_SECRET=replace-with-64-byte-random-hex
OPS_SESSION_TTL_HOURS=8
OPS_COOKIE_NAME=rel_ops_session
OPS_COOKIE_SECURE=false
