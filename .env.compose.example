POSTGRES_DB=relational_encyclopedia
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=https://your-frontend-host
SEED_ON_STARTUP=true
OPS_AUTH_ENABLED=true
OPS_SHARED_PASSWORD=replace-with-unique-shared-passphrase
OPS_SESSION_SECRET=replace-with-64-byte-random-hex
OPS_SESSION_TTL_HOURS=8
OPS_COOKIE_NAME=rel_ops_session
OPS_COOKIE_SECURE=true

FRONTEND_PORT=3000
FRONTEND_PUBLIC_API_BASE_URL=https://your-api-host
