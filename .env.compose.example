POSTGRES_DB=relational_encyclopedia
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=https://your-frontend-host
SEED_ON_STARTUP=true
OPS_AUTH_ENABLED=true
OPS_SHARED_PASSWORD=replace-with-unique-shared-passphrase
OPS_SESSION_SECRET=replace-with-64-byte-random-hex
OPS_SESSION_TTL_HOURS=8
OPS_COOKIE_NAME=rel_ops_session
OPS_COOKIE_SECURE=true
API_META_ENABLED=true
API_VERSION=1.0.0
SCHEMA_VERSION=1
BUILD_SHA=dev
REQUEST_CORRELATION_ENABLED=true

FRONTEND_PORT=3000
FRONTEND_PUBLIC_API_BASE_URL=/api
FRONTEND_API_VERSION_CHECK_ENABLED=true
FRONTEND_EXPECTED_API_VERSION=1.0.0
FRONTEND_CLIENT_REQUEST_ID_ENABLED=true
